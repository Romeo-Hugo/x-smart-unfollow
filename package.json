  },
  "homepage": "https://github.com/yourusername/x-smart-unfollow#readme",
  "devDependencies": {
    "eslint": "^8.55.0",
    "prettier": "^3.1.0"
  },
  "files": [
    "manifest.json",
    "popup.html",
    "popup.js",
    "content.js",
    "background.js",
